<ui:FluentWindow x:Class="GlumChip8.GUI.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:GlumChip8.GUI"
                 xmlns:VM="clr-namespace:GlumChip8.GUI.ViewModels"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="MainWindow" Height="450" Width="800"
                 Background="#2d2d2d"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Loaded="FluentWindow_Loaded"
                 WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <DataTemplate x:Key="RomCollectionTemplate">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="5" Width="120" Height="160">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,2" Text="{Binding Key}" HorizontalAlignment="Center"/>
                                    <ui:Button HorizontalAlignment="Center"
                                           Click="Play_Button_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Play"/>
                                            <ui:SymbolIcon Margin="2" Grid.Column="1" Symbol="Games48"/>
                                        </Grid>
                                    </ui:Button>
                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DataTemplate>
    </ui:FluentWindow.Resources>
    <ui:FluentWindow.DataContext>
        <VM:MainViewModel/>
    </ui:FluentWindow.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="TitleBar"
            Icon="./Assets/icon.png">
            <ui:TitleBar.Title>
                <MultiBinding StringFormat="GlumChip8 - {0}">
                    <Binding Path="CurrentRomPath" />
                </MultiBinding>
            </ui:TitleBar.Title>
        </ui:TitleBar>

        <Border Padding="10" Grid.Row="1">
            <!-- Main frame -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Menu>
                            <MenuItem Header="File">
                                <MenuItem Command="{Binding OpenRomCommand}" Header="Open ROM (.ch8)..."/>
                                <MenuItem Command="{Binding ResetRomCommand}"  Header="Restart ROM"/>
                                <MenuItem Command="{Binding CloseRomCommand}" Header="Close ROM"/>
                                <Separator/>
                                <MenuItem Command="{Binding RefreshCommand}"  Header="Reload ROMs"/>
                            </MenuItem>
                        </Menu>
                        <CheckBox Content="Display FPS" Command="{Binding ToggleFpsCommand}"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Grid.Column="1">
                        <ui:Button Command="{Binding TogglePauseCommand}">
                            <ui:SymbolIcon Symbol="{Binding PauseRomSymbol}"  />
                        </ui:Button>
                        <ui:Button Margin="10 0 0 0" Command="{Binding CloseRomCommand}">
                            <ui:SymbolIcon Symbol="Stop24"  />
                        </ui:Button>
                        <ui:Button Command="{Binding ResetRomCommand}" Margin="10 0 0 0">
                            <ui:SymbolIcon Symbol="ArrowClockwise48"  />
                        </ui:Button>
                    </StackPanel>
                </Grid>
                <ContentControl Grid.Row="1">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <!-- Default: Show the Raylib Host -->
                            <Setter Property="Content" Value="{Binding RaylibHost}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCollection}" Value="True">
                                    <Setter Property="Content" Value="{Binding RomCollection}" />
                                    <Setter Property="ContentTemplate" Value="{StaticResource RomCollectionTemplate}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>